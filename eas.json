{
  "cli": {
    "version": ">= 5.0.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "channel": "staging"
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "withoutCredentials": false
      },
      "channel": "production",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "EXPO_UNSTABLE_CORE_AUTOLINKING": "1"
      }
    }
  }
}
