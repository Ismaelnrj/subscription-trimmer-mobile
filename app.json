{
  "expo": {
    "name": "Trimio",
    "slug": "subtrimmer",
    "scheme": "trimio",
    "version": "1.0.1",
    "runtimeVersion": "1.0.1",
    "updates": {
      "url": "https://u.expo.dev/18a3e059-0c9c-49df-b485-21240d7e283a",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },

    "icon": "./assets/icon.png",
    "primaryColor": "#7746DD",

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBFBFD"
    },

    "assetBundlePatterns": [
      "**/*"
    ],

    "android": {
      "package": "com.trimio.app",
      "versionCode": 32,
      "edgeToEdgeEnabled": false,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7746DD"
      },
      "permissions": [
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_VISUAL_USER_SELECTED",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ]
    },

    "ios": {
      "bundleIdentifier": "com.trimio.app"
    },

    "web": {
      "favicon": "./assets/favicon.png"
    },

    "extra": {
      "apiUrl": "https://subscription-trimmer-mobile-production.up.railway.app",
      "googleAndroidClientId": "555155282969-6n0085a1n6oe0c8cdq2lqhh2aeh7274m.apps.googleusercontent.com",
      "googleIosClientId": "",
      "googleWebClientId": "555155282969-3piu7cjadlnak8v0kqfikf0cffm84eds.apps.googleusercontent.com",
      "eas": {
        "projectId": "18a3e059-0c9c-49df-b485-21240d7e283a"
      }
    },
    "plugins": [
      "expo-updates",
      "@react-native-google-signin/google-signin",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7746DD"
        }
      ],
      "./plugins/withGradleFixes.js",
      "./plugins/withAutolinkingConfigFix.js"
    ],
    "owner": "ismaelnrj"
  }
}
