{
  "expo": {
    "name": "Trimio",
    "slug": "trimio",
    "scheme": "trimio",
    "version": "1.0.1",
    "runtimeVersion": {
      "policy": "nativeVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/18a3e059-0c9c-49df-b485-21240d7e283a",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },

    "icon": "./assets/icon.png",

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9FAFB"
    },

    "assetBundlePatterns": [
      "**/*"
    ],

    "android": {
      "package": "com.trimio.app",
      "versionCode": 18,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7746DD"
      },
      "permissions": [
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_VISUAL_USER_SELECTED",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ]
    },

    "ios": {
      "bundleIdentifier": "com.trimio.app"
    },

    "web": {
      "favicon": "./assets/favicon.png"
    },

    "extra": {
      "apiUrl": "https://subscription-trimmer-mobile-production.up.railway.app",
      "eas": {
        "projectId": "18a3e059-0c9c-49df-b485-21240d7e283a"
      }
    },
    "plugins": [
      "expo-updates",
      "sentry-expo",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7746DD"
        }
      ]
    ],
    "owner": "ismaelnrj"
  }
}
